# =============================================================================
# Maxim — Environment Variable Template
# =============================================================================
# Copy this file to .env (gitignored) and fill in values as needed.
# Most Maxim features work without ANY env vars — these are optional enhancements.
# =============================================================================

# ----- Portfolio Root -----
# Where Maxim scans for projects when sync_portfolio runs.
# Default: E:/Projects (Windows) or ~/Projects (Mac/Linux)
MXM_PROJECTS_ROOT=E:/Projects

# ----- Model Provider (Optional) -----
# Maxim is model-agnostic. Set the active provider per `config/project-manifest.json`
# tech_stack section, or override per-session via this env var.
# Valid: anthropic | openai | gemini | mistral | local
MXM_MODEL_PROVIDER=anthropic

# ----- Anthropic (Default) -----
# Required ONLY if you run Maxim scripts that call Claude API directly
# (Claude Code itself manages its own credentials separately).
ANTHROPIC_API_KEY=

# ----- OpenAI (Optional) -----
# Used by:
#   - mxm-voice (when VoiceMode is configured to use OpenAI cloud STT/TTS
#     instead of local Whisper/Kokoro)
#   - any agent routed to gpt-* models
OPENAI_API_KEY=

# ----- Gemini (Optional) -----
GOOGLE_API_KEY=

# ----- Mistral (Optional) -----
MISTRAL_API_KEY=

# ----- VoiceMode Configuration (Optional) -----
# Set to "true" to require voicemode for /mxm-voice; otherwise gracefully degrades.
VOICEMODE_REQUIRED=false
# Save audio recordings (true) or discard after transcription (false)
VOICEMODE_SAVE_AUDIO=false

# ----- Usage-Aware Scheduler (Optional) -----
# Override default thresholds in config/scheduler-thresholds.json
# Pause scheduled tasks when 5-hour utilization >= this %
MXM_SCHEDULER_FIVE_HOUR_PAUSE_AT=80
# Pause when 7-day utilization >= this %
MXM_SCHEDULER_SEVEN_DAY_PAUSE_AT=85
# Pause when 7-day Opus utilization >= this %
MXM_SCHEDULER_SEVEN_DAY_OPUS_PAUSE_AT=80

# ----- MemPalace Integration (Optional) -----
# Path to MemPalace data directory (defaults to ~/.mempalace)
MEMPALACE_DATA_DIR=

# ----- Build Target (Optional) -----
# For projects using remote-first SSH builds (per project-manifest.json build_target)
MXM_BUILD_REMOTE_HOST=
MXM_BUILD_REMOTE_USER=
MXM_BUILD_REMOTE_PROJECT_PATH=

# ----- Telemetry (v1.1.0+) -----
# Set to "false" to disable eval harness telemetry emission
MXM_TELEMETRY_ENABLED=true

# ----- Super User Mode (Use With Care) -----
# Set in project-manifest.json instead — env override for CI/dev only.
# When true: suppresses CSO auto-loop, ethics gates, compliance pre-enforcement.
MXM_SUPER_USER=false
